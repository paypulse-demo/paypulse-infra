{
  "title": "PayPulse Production Overview",
  "description": "Live metrics for the PayPulse notifications API",
  "widgets": [
    {
      "definition": {
        "type": "group",
        "title": "Service Health",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "query_value",
              "title": "Request Rate",
              "title_size": "16",
              "title_align": "left",
              "requests": [
                {
                  "q": "sum:trace.express.request.hits{service:paypulse-api}.as_rate()",
                  "aggregator": "avg",
                  "conditional_formats": [
                    { "comparator": ">", "value": 0, "palette": "white_on_green" }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 1,
              "custom_unit": "req/s"
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Error Rate (%)",
              "title_size": "16",
              "title_align": "left",
              "requests": [
                {
                  "q": "(sum:trace.express.request.errors{service:paypulse-api}.as_rate() / sum:trace.express.request.hits{service:paypulse-api}.as_rate()) * 100",
                  "aggregator": "avg",
                  "conditional_formats": [
                    { "comparator": "<", "value": 1, "palette": "white_on_green" },
                    { "comparator": ">=", "value": 1, "palette": "white_on_yellow" },
                    { "comparator": ">=", "value": 5, "palette": "white_on_red" }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 2,
              "custom_unit": "%"
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "p95 Latency",
              "title_size": "16",
              "title_align": "left",
              "requests": [
                {
                  "q": "p95:trace.express.request.duration{service:paypulse-api}",
                  "aggregator": "avg",
                  "conditional_formats": [
                    { "comparator": "<", "value": 100, "palette": "white_on_green" },
                    { "comparator": ">=", "value": 100, "palette": "white_on_yellow" },
                    { "comparator": ">=", "value": 500, "palette": "white_on_red" }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 0,
              "custom_unit": "ms"
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Pod Count",
              "title_size": "16",
              "title_align": "left",
              "requests": [
                {
                  "q": "max:kubernetes_state.deployment.replicas_available{kube_deployment:paypulse-api,kube_namespace:paypulse-prod}",
                  "aggregator": "last"
                }
              ],
              "autoscale": false,
              "precision": 0
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "title": "Traffic and Errors Over Time",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "Request Rate Over Time",
              "show_legend": true,
              "requests": [
                {
                  "q": "sum:trace.express.request.hits{service:paypulse-api}.as_rate()",
                  "display_type": "line",
                  "style": { "palette": "dog_classic", "line_type": "solid", "line_width": "normal" }
                }
              ],
              "yaxis": { "label": "req/s", "scale": "linear", "min": "0", "include_zero": true }
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "HTTP Status Codes",
              "show_legend": true,
              "requests": [
                {
                  "q": "sum:trace.express.request.hits{service:paypulse-api} by {http.status_code}.as_rate()",
                  "display_type": "bars",
                  "style": { "palette": "cool", "line_type": "solid", "line_width": "normal" }
                }
              ],
              "yaxis": { "label": "req/s", "scale": "linear", "min": "0", "include_zero": true }
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Latency Distribution",
              "show_legend": true,
              "requests": [
                {
                  "q": "p50:trace.express.request.duration{service:paypulse-api}",
                  "display_type": "line",
                  "style": { "palette": "green", "line_type": "solid", "line_width": "normal" }
                },
                {
                  "q": "p95:trace.express.request.duration{service:paypulse-api}",
                  "display_type": "line",
                  "style": { "palette": "orange", "line_type": "solid", "line_width": "normal" }
                },
                {
                  "q": "p99:trace.express.request.duration{service:paypulse-api}",
                  "display_type": "line",
                  "style": { "palette": "red", "line_type": "solid", "line_width": "normal" }
                }
              ],
              "yaxis": { "label": "ms", "scale": "linear", "min": "0", "include_zero": true }
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "title": "Infrastructure",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "CPU Usage by Pod",
              "show_legend": true,
              "requests": [
                {
                  "q": "avg:kubernetes.cpu.usage.total{kube_deployment:paypulse-api} by {pod_name}",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Memory Usage by Pod",
              "show_legend": true,
              "requests": [
                {
                  "q": "avg:kubernetes.memory.usage{kube_deployment:paypulse-api} by {pod_name}",
                  "display_type": "line"
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Pod Restarts",
              "show_legend": true,
              "requests": [
                {
                  "q": "sum:kubernetes.containers.restarts{kube_deployment:paypulse-api}.as_count()",
                  "display_type": "bars",
                  "style": { "palette": "warm" }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "template_variables": [],
  "layout_type": "ordered",
  "is_read_only": false,
  "notify_list": [],
  "reflow_type": "auto"
}